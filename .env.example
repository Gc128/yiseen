# OPENAI_API_KEY / DEEPSEEK_API_KEY: Required for DeepSeek API calls.
# Keep this server-side only. Do not expose it with a VITE_ prefix.
OPENAI_API_KEY="YOUR_DEEPSEEK_OR_OPENAI_COMPATIBLE_KEY"

# DeepSeek is OpenAI-compatible. Override these only when switching providers.
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_TIMEOUT_MS="45000"
FIRESTORE_DATABASE_ID="ai-studio-9e78684d-5bd5-4001-9fa5-f6b8a6fda0e8"

# Optional Firebase Auth custom OIDC provider id for WeChat.
VITE_WECHAT_PROVIDER_ID="oidc.wechat"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
